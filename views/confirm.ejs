<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>予約内容確認 | SiegSports</title>
  <link rel="stylesheet" href="/css/guest-form.css">
</head>
<body>
  <div class="page">

    <header class="header">
      <h1>SiegSports</h1>
    </header>

    <section class="section-title">
      <h2>予約内容確認</h2>
      <p class="desc">入力内容をご確認ください</p>
    </section>

    <section class="summary-box">
      <h3>予約内容</h3>

      <div class="summary-item">
        <span class="label">メニュー</span>
        <span class="value"><%= plan %></span>
      </div>

      <div class="summary-item">
        <span class="label">日付</span>
        <span class="value"><%= date %></span>
      </div>

      <div class="summary-item">
        <span class="label">時間</span>
        <span class="value"><%= time %></span>
      </div>

      <div class="summary-item">
        <span class="label">保護者氏名</span>
        <span class="value"><%= parentName %></span>
      </div>

      <div class="summary-item">
        <span class="label">お子さま氏名</span>
        <span class="value"><%= childName %></span>
      </div>

      <div class="summary-item">
        <span class="label">お子さま氏名（ふりがな）</span>
        <span class="value"><%= childKana %></span>
      </div>

      <div class="summary-item">
        <span class="label">学年</span>
        <span class="value"><%= grade %></span>
      </div>

      <div class="summary-item">
        <span class="label">メールアドレス</span>
        <span class="value"><%= email %></span>
      </div>

      <div class="summary-item">
        <span class="label">電話番号</span>
        <span class="value"><%= phone %></span>
      </div>

      <div class="summary-item">
        <span class="label">備考</span>
        <span class="value"><%= note || 'なし' %></span>
      </div>
    </section>

    <form action="/complete" method="POST">
      <input type="hidden" name="plan" value="<%= rawPlan %>">
        <input type="hidden" name="date" value="<%= date %>">
        <input type="hidden" name="rawDate" value="<%= rawDate %>">
        <input type="hidden" name="time" value="<%= time %>">
        <input type="hidden" name="slotId" value="<%= slotId %>">
        <input type="hidden" name="parentName" value="<%= parentName %>">
        <input type="hidden" name="childName" value="<%= childName %>">
        <input type="hidden" name="childKana" value="<%= childKana %>">
        <input type="hidden" name="grade" value="<%= grade %>">
        <input type="hidden" name="email" value="<%= email %>">
        <input type="hidden" name="phone" value="<%= phone %>">
        <input type="hidden" name="note" value="<%= note %>">
      
        <div class="form-actions" style="margin: 0 20px 40px;">
          <button type="button" class="back-button" onclick="history.back()">戻る</button>
          <button type="submit" class="submit-button">この内容で予約する</button>
        </div>
      </form>

  </div>
</body>
</html>