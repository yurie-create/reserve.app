<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ゲスト予約 | SiegSports</title>
  <link rel="stylesheet" href="/css/guest-form.css">
</head>
<body>
  <div class="page">

    <header class="header">
      <h1>SiegSports</h1>
    </header>

    <section class="section-title">
      <h2>ゲスト予約</h2>
      <p class="desc">必要事項をご入力ください</p>
    </section>

    <section class="summary-box">
        <h3>予約内容</h3>
        <div class="summary-item">
          <span class="label">メニュー</span>
          <span class="value"><%= typeof plan !== 'undefined' ? plan : '未選択' %></span>
        </div>
      
        <div class="summary-item">
          <span class="label">日付</span>
          <span class="value"><%= typeof date !== 'undefined' ? date : '未選択' %></span>
        </div>
      
        <div class="summary-item">
          <span class="label">時間</span>
          <span class="value"><%= typeof time !== 'undefined' ? time : '未選択' %></span>
        </div>
      </section>
      <form class="form-box" action="/confirm" method="GET" onsubmit="return validateForm()">
        <input type="hidden" name="plan" value="<%= rawPlan %>">
        <input type="hidden" name="date" value="<%= date %>">
        <input type="hidden" name="rawDate" value="<%= rawDate %>">
        <input type="hidden" name="time" value="<%= time %>">
        <input type="hidden" name="slotId" value="<%= slotId %>">
      
      
        <div class="form-group">
          <p style="font-size: 13px; color: #666; margin-bottom: 12px; line-height: 1.6;">
            ※ご兄弟でご利用の場合は、お手数ですがお一人ずつ登録をお願いいたします。<br>
          </p>
          <label>お名前（本人）</label>
          <input type="text" id="childName" name="childName" placeholder="例）山田 太郎">
          <p style="font-size: 12px; color: #666; margin-top: 4px;">
            ※お子さまの場合はお子さまのお名前をご入力ください
          </p>
        </div>

        <div class="form-group">
          <label for="childKana">ふりがな</label>
          <input type="text" id="childKana" name="childKana" placeholder="例）やまだ たろう">
        </div>
      
        <div class="form-group">
          <label for="grade">学年/年齢</label>
          <input type="text" id="grade" name="grade" required>
          <p style="font-size: 12px; color: #666; margin-top: 4px;">
            ※学生は学年を大人の方は年齢をご入力ください
          </p>
        </div>


        <div class="form-group">
          <label for="parentName">保護者氏名(任意)</label>
          <input type="text" id="parentName" name="parentName" placeholder="例）山田 花子">
        </div>
      
        <div class="form-group">
          <label for="email">メールアドレス</label>
          <input type="email" id="email" name="email" placeholder="例）sample@example.com">
        </div>
      
        <div class="form-group">
          <label for="phone">電話番号</label>
          <input type="tel" id="phone" name="phone" placeholder="例）09012345678">
        </div>
      
        <div class="form-group">
          <label for="note">備考</label>
          <textarea id="note" name="note" rows="4" placeholder="ご質問やご相談があればご記入ください"></textarea>
        </div>
      
        <div class="form-actions">
          <button type="button" class="back-button" onclick="history.back()">戻る</button>
          <button type="submit" class="submit-button">確認画面へ</button>
        </div>
      </form>

  </div>
  <script>
    function validateForm() {
      const parentName = document.getElementById("parentName").value.trim();
      const childName = document.getElementById("childName").value.trim();
      const childKana = document.getElementById("childKana").value.trim();
      const grade = document.getElementById("grade").value;
      const email = document.getElementById("email").value.trim();
      const phone = document.getElementById("phone").value.trim();
    
      
    
      if (!childName) {
        alert("お子さま氏名を入力してください");
        return false;
      }

      if (!childKana) {
        alert("お子さま氏名（ふりがな）を入力してください");
        return false;
      }
      if (!grade) {
        alert("学年を選択してください");
        return false;
      }
    
      if (!email) {
        alert("メールアドレスを入力してください");
        return false;
      }
    
      if (!phone) {
        alert("電話番号を入力してください");
        return false;
      }
    
      return true;
    }
    </script>
</body>
</html>