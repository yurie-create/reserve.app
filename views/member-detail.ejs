<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>会員詳細 | SiegSports</title>
  <link rel="stylesheet" href="/css/guest-form.css">
</head>
<body>
  <div class="page">

    <header class="header">
      <h1>会員詳細</h1>
    </header>

    <section class="summary-box">
      <div class="summary-item">
        <span class="label">お名前</span>
        <span class="value"><%= member.name %></span>
      </div>

      <div class="summary-item">
        <span class="label">ふりがな</span>
        <span class="value"><%= member.kana || 'なし' %></span>
      </div>

      <div class="summary-item">
        <span class="label">保護者名</span>
        <span class="value"><%= member.guardian_name || 'なし' %></span>
      </div>

      <div class="summary-item">
        <span class="label">学年 / 年齢</span>
        <span class="value"><%= member.grade || 'なし' %></span>
      </div>

      <div class="summary-item">
        <span class="label">メール</span>
        <span class="value"><%= member.email || 'なし' %></span>
      </div>

      <div class="summary-item">
        <span class="label">電話</span>
        <span class="value"><%= member.phone || 'なし' %></span>
      </div>

      <div class="summary-item">
        <span class="label">備考</span>
        <span class="value"><%= member.note || 'なし' %></span>
      </div>
    </section>

    <div class="bottom-actions">
      <button class="back-button" type="button" onclick="history.back()">戻る</button>
    </div>

  </div>
</body>
</html>