<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>会員一覧 | 管理画面</title>
  <style>
    body {
      font-family: sans-serif;
      background: #f7f7f7;
      margin: 0;
      padding: 24px;
      color: #222;
    }

    .page {
      max-width: 1100px;
      margin: 0 auto;
    }

    h1 {
      margin-bottom: 24px;
      font-size: 28px;
    }

    .top-link {
      display: inline-block;
      margin-bottom: 20px;
      color: #2563eb;
      text-decoration: none;
      font-weight: 600;
    }

    .table-wrap {
      background: #fff;
      border-radius: 16px;
      overflow-x: auto;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 900px;
    }

    th,
    td {
      padding: 14px 12px;
      border-bottom: 1px solid #eee;
      text-align: left;
      vertical-align: top;
      font-size: 14px;
      line-height: 1.6;
    }

    th {
      background: #fafafa;
      font-weight: 700;
      white-space: nowrap;
    }

    tr:last-child td {
      border-bottom: none;
    }

    .empty {
      background: #fff;
      padding: 24px;
      border-radius: 16px;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
    }

    @media (max-width: 768px) {
      body {
        padding: 16px;
      }

      h1 {
        font-size: 22px;
      }

      th,
      td {
        font-size: 13px;
        padding: 12px 10px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <a href="/admin" class="top-link">← 管理画面トップへ戻る</a>

    <h1>会員一覧</h1>

    <% if (!members || members.length === 0) { %>
      <div class="empty">
        会員はまだ登録されていません。
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>名前</th>
              <th>ふりがな</th>
              <th>学年 / 年齢</th>
              <th>保護者名</th>
              <th>メール</th>
              <th>電話</th>
              <th>備考</th>
              <th>月謝</th>
              <th>コース</th>
              <th>入会月</th>
            </tr>
          </thead>
          <tbody>
            <% members.forEach(member => { %>
              <tr>
                <td><%= member.id %></td>
                <td><%= member.name || '' %></td>
                <td><%= member.kana || '' %></td>
                <td><%= member.grade || '' %></td>
                <td><%= member.guardian_name || '' %></td>
                <td><%= member.email || '' %></td>
                <td><%= member.phone || '' %></td>
                <td><%= member.note || '' %></td>
                <td>
                    <% if (member.course) { %>
                      〇
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  
                  <td>
                    <% if (member.course) { %>
                      <%= formatCourse(member.course) %>
                    <% } %>
                  </td>
                  
                  <td>
                    <% if (member.start_month) { %>
                      <%= member.start_month %>
                    <% } %>
                  </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</body>
</html>